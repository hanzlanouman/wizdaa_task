{
  "name": "examplehr-time-off-service",
  "version": "1.0.0",
  "description": "ExampleHR Time-Off Microservice",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:timeoff": "nest start",
    "start:hcm": "nest start --entryFile hcm-main",
    "start:dev": "nest start --watch",
    "start:dev:timeoff": "nest start --watch",
    "start:dev:hcm": "nest start --watch --entryFile hcm-main",
    "start:prod:timeoff": "node dist/main.js",
    "start:prod:hcm": "node dist/hcm-main.js",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "zip": "zip -FSr examplehr-time-off-service.zip . -x \"examplehr-time-off-service.zip\" \"node_modules/*\" \"dist/*\" \"coverage/*\" \".git/*\" \".codex\" \"data/*\" \"docs/diagrams/*\" \"*.sqlite\" \"*.sqlite-*\" \".cache/*\" \"*.log\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*(\\.spec|\\.e2e-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/main.ts",
      "!src/hcm-main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "sqlite3"
    ]
  }
}
